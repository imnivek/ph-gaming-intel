---
import BaseLayout from '../layouts/BaseLayout.astro';
import CategoryGrid from '../components/CategoryGrid.astro';
import {
  CATEGORIES,
  SITE,
  articlesByCategory,
  articlesByTag,
  articleUrl,
  type ArticleCategory,
} from '../data/articles';

export function getStaticPaths() {
  return CATEGORIES.map((c) => ({ params: { category: c.slug } }));
}

const { category } = Astro.params;
const def = CATEGORIES.find((c) => c.slug === category)!;

const items = def.isTag
  ? articlesByTag(def.label as string)
  : articlesByCategory(def.label as ArticleCategory);

const pageTitle = `${def.label} | ${SITE.name}`;
const pageDescription = def.description;

const collectionJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": pageTitle,
  "description": pageDescription,
  "url": `${SITE.url}/${def.slug}`,
  "isPartOf": { "@type": "WebSite", "name": SITE.name, "url": SITE.url },
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": items.length,
    "itemListElement": items.map((a, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "url": articleUrl(a.slug),
      "name": a.title,
    })),
  },
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": `${SITE.url}/` },
    { "@type": "ListItem", "position": 2, "name": String(def.label), "item": `${SITE.url}/${def.slug}` },
  ],
};
---

<BaseLayout title={pageTitle} description={pageDescription} jsonLd={collectionJsonLd}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  </Fragment>

  <section class="mt-section mb-section">
    <div class="section-wrap">
      <header style="margin-bottom: 48px; max-width: 760px;">
        <p style="color: var(--gold); font-family: var(--font-ui); text-transform: uppercase; letter-spacing: 2px; font-size: 13px; margin: 0 0 8px;">Section</p>
        <h1 style="font-size: 48px; margin: 0 0 16px; line-height: 1.1;">{def.label}</h1>
        <p style="font-size: 18px; line-height: 1.6; color: #555;">{def.description}</p>
        <p style="font-size: 14px; color: #888; margin-top: 16px; font-family: var(--font-ui); text-transform: uppercase; letter-spacing: 1px;">
          {items.length} {items.length === 1 ? 'article' : 'articles'}
        </p>
      </header>

      {items.length > 0 ? (
        <CategoryGrid articles={items} />
      ) : (
        <p style="font-size: 18px; color: #777;">No articles in this section yet. Check back soon.</p>
      )}
    </div>
  </section>
</BaseLayout>
