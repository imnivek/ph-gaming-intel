---
import BaseLayout from '../layouts/BaseLayout.astro';

const siteUrl = 'https://phgamingintel.com';

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      "name": "PH Gaming Intel",
      "url": `${siteUrl}/`,
      "description": "Philippines gaming industry news, regulatory analysis, and data tools.",
      "publisher": { "@id": `${siteUrl}/#organization` },
      "potentialAction": {
        "@type": "SearchAction",
        "target": `${siteUrl}/?s={search_term_string}`,
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@type": "Organization",
      "@id": `${siteUrl}/#organization`,
      "name": "PH Gaming Intel",
      "url": `${siteUrl}/`,
      "logo": { "@type": "ImageObject", "url": `${siteUrl}/logo.png` },
      "sameAs": []
    },
    {
      "@type": "ItemList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inside CEZA and Aurora: The Philippine Economic Zones That Defined a Gaming Era — and the One That Refused to Host POGOs", "url": `${siteUrl}/articles/ceza-aurora-economic-zones-gaming-history-2026.html` },
        { "@type": "ListItem", "position": 2, "name": "PAGCOR Q1 2026 Official Disclosure: Philippine Gross Gaming Revenue Falls 16% to PHP 87.6B", "url": `${siteUrl}/articles/pagcor-q1-2026-official-ggr-disclosure.html` },
        { "@type": "ListItem", "position": 3, "name": "Senate Anti-Online Gambling Act Hearing Reopens as Tulfo Pushes Total Ban and Meta No-Shows", "url": `${siteUrl}/articles/senate-anti-online-gambling-act-tulfo-2026.html` },
        { "@type": "ListItem", "position": 4, "name": "The DigiPlus 50 Percent: What Market Concentration Means for the Philippine Online Gambling Sector", "url": `${siteUrl}/articles/digiplus-market-dominance-pigo-concentration-analysis.html` },
        { "@type": "ListItem", "position": 5, "name": "PAGCOR Cuts Live Sports Betting GGR Share Rate from 17.5% to 15%: Why the Math Changed", "url": `${siteUrl}/articles/pagcor-sports-betting-ggr-share-rate-cut-2026.html` },
        { "@type": "ListItem", "position": 6, "name": "After the Bell: The Resurgent Underground of Philippine Cash Gambling", "url": `${siteUrl}/articles/philippine-underground-cash-gambling-post-delinking.html` },
        { "@type": "ListItem", "position": 7, "name": "Interpol Issues Red Notice for Philippine Gambling Tycoon Atong Ang Over Sabungeros Disappearances", "url": `${siteUrl}/articles/atong-ang-interpol-red-notice-sabungeros-2026.html` },
        { "@type": "ListItem", "position": 8, "name": "ArenaPlus Becomes the NBA's First Official Betting Partner in the Philippines", "url": `${siteUrl}/articles/arenaplus-nba-philippine-betting-partner-2026.html` },
        { "@type": "ListItem", "position": 9, "name": "DigiPlus's Brazil Bet: Eight Months Into GamePlus, BingoPlus Set to Follow in 2026", "url": `${siteUrl}/articles/digiplus-gameplus-brazil-international-expansion.html` },
        { "@type": "ListItem", "position": 10, "name": "The E-Wallet Delinking Order, Six Months On: What the August 2025 BSP Directive Did to Philippine Online Gaming", "url": `${siteUrl}/articles/e-wallet-delinking-six-months-philippines-gaming.html` },
        { "@type": "ListItem", "position": 11, "name": "Bloomberry Swings to PHP 2.6B Net Loss in 2025 as VIP Slump and MegaFUNalo Costs Bite", "url": `${siteUrl}/articles/bloomberry-fy-2025-net-loss.html` },
        { "@type": "ListItem", "position": 12, "name": "DigiPlus Q1 2026 Net Income Drops 33% to PHP 2.8B as Delinking and Fuel Crisis Weigh", "url": `${siteUrl}/articles/digiplus-1q-2026-earnings-drop.html` },
        { "@type": "ListItem", "position": 13, "name": "PAGCOR Launches 24/7 National Problem Gambling Helpline in Pasay City", "url": `${siteUrl}/articles/pagcor-npgh-helpline-launch-2026.html` },
        { "@type": "ListItem", "position": 14, "name": "The Post-POGO Cambodia Scam-Casino Nexus: OFAC, Chen Zhi, and What Sihanoukville Looks Like Now", "url": `${siteUrl}/articles/post-pogo-cambodia-scam-network-structure-2026.html` },
        { "@type": "ListItem", "position": 15, "name": "PAGCOR Sets August 1 Deadline to Decommission Non-Compliant B2B Gaming Systems", "url": `${siteUrl}/articles/pagcor-b2b-system-decommissioning-august-2026.html` },
        { "@type": "ListItem", "position": 16, "name": "Cambodia Revokes Zhong Huawei Casino License as Sihanoukville Crackdown Hits Eight Operators", "url": `${siteUrl}/articles/cambodia-revokes-zhong-huawei-casino-license.html` },
        { "@type": "ListItem", "position": 17, "name": "BingoPlus Reports PHP 2.25 Trillion in Cumulative Payouts at 2026 Anniversary", "url": `${siteUrl}/articles/bingoplus-anniversary-2026-payouts.html` },
        { "@type": "ListItem", "position": 18, "name": "From Pasay to Sihanoukville: A POGO Worker's Migration", "url": `${siteUrl}/articles/pasay-to-sihanoukville-worker-migration.html` },
        { "@type": "ListItem", "position": 19, "name": "Senate Bill 2580 in Plain English: The PAGCOR Reform That Wasn't", "url": `${siteUrl}/articles/senate-bill-2580-pagcor-reform-failed.html` },
        { "@type": "ListItem", "position": 20, "name": "GCash Casino Partnerships Hit 47 in Q2 2026 as Cashless Push Accelerates", "url": `${siteUrl}/articles/gcash-casino-partnerships-q2-2026.html` },
        { "@type": "ListItem", "position": 21, "name": "Why Cambodia Won the POGO Refugees: A Geopolitical Read", "url": `${siteUrl}/articles/why-cambodia-won-pogo-refugees.html` },
        { "@type": "ListItem", "position": 22, "name": "Manila Bay at 4 AM: The Hidden Shift Change Inside PH Integrated Resorts", "url": `${siteUrl}/articles/manila-bay-4am-ir-workers.html` },
        { "@type": "ListItem", "position": 23, "name": "Cambodia Gaming License Framework: Three-Tier System Targets Former POGO Operators", "url": `${siteUrl}/articles/cambodia-gaming-license-pogo.html` },
        { "@type": "ListItem", "position": 24, "name": "PAGCOR Privatization Bill SB 2814 Advances in Senate Committee", "url": `${siteUrl}/articles/pagcor-privatization-bill.html` },
        { "@type": "ListItem", "position": 25, "name": "Bloomberry Resorts Q1 2026: Revenue Down 18% as VIP Rolling Chip Drops 26%", "url": `${siteUrl}/articles/bloomberry-q1-2026-solaire.html` },
        { "@type": "ListItem", "position": 26, "name": "PIGO vs e-Games: The Regulatory Maze Mapped", "url": `${siteUrl}/articles/pigo-vs-egames-regulatory-maze.html` },
        { "@type": "ListItem", "position": 27, "name": "Best PAGCOR Licensed Online Casinos Philippines 2026", "url": `${siteUrl}/articles/pagcor-licensed-casinos-guide-2026.html` },
        { "@type": "ListItem", "position": 28, "name": "Philippine GGR Falls 15.8% to $1.42bn in Q1 2026", "url": `${siteUrl}/articles/philippine-ggr-falls-q1-2026-pagcor.html` },
        { "@type": "ListItem", "position": 29, "name": "Okada Play Commercial Launch: PhilWeb and Tiger Resort Go Digital", "url": `${siteUrl}/articles/okada-play-commercial-launch.html` },
        { "@type": "ListItem", "position": 30, "name": "Altenar Powers DigiPlus ArenaPlus Sportsbook in the Philippines", "url": `${siteUrl}/articles/altenar-arenaplus-sportsbook.html` }
      ]
    }
  ]
};
---

<BaseLayout
  title="PH Gaming Intel — Philippines Gaming Industry News & Analysis"
  description="PH Gaming Intel covers the Philippines gaming industry with in-depth news, regulatory analysis, PAGCOR updates, POGO tracking, and IR resort coverage."
  activePage="news"
  jsonLd={jsonLd}
>

  <!-- HERO — Featured Story -->
  <section class="hero-featured" aria-label="Featured story">
    <img src="/hero/pasay-to-sihanoukville-worker-migration.png"
         alt="A POGO worker's migration from Pasay to Sihanoukville — layered map and silhouettes"
         width="1920" height="1080" loading="eager">
    <div class="overlay">
      <div class="overlay-inner">
        <span class="tag tag-longread">Longread</span>
        <h1>From Pasay to Sihanoukville: A POGO Worker's Migration</h1>
        <p class="dek">When the Philippine offshore gaming industry was shut down in 2024, the buildings emptied. The workers had to go somewhere. A reconstructed account of one path — and what the journey reveals about a regional labor market in transition.</p>
        <p class="meta">May 27, 2026 &middot; 22 min read &middot; Editorial Score 10/10</p>
        <a href="/articles/pasay-to-sihanoukville-worker-migration.html" style="display:inline-block;margin-top:16px;padding:12px 28px;border-radius:8px;background:var(--gold);color:var(--dark);font-family:var(--font-ui);font-size:14px;font-weight:700;letter-spacing:.5px;transition:background .2s;">Read the Full Story</a>
      </div>
    </div>
  </section>

  <!-- LATEST NEWS -->
  <section class="mt-section mb-section" id="latest-news" aria-label="Latest news">
    <div class="section-wrap">
      <h2 class="section-title">Latest News</h2>
      <div class="card-grid">

        <a href="/articles/pagcor-q1-2026-official-ggr-disclosure.html" class="card">
          <div class="card-img">
            <img src="/hero/pagcor-q1-2026-official-ggr-disclosure.png"
                 alt="PAGCOR Q1 2026 official gross gaming revenue disclosure"
                 width="640" height="360" loading="lazy">
          </div>
          <div class="card-body">
            <span class="tag tag-news">News</span>
            <h3>PAGCOR Q1 2026 Official Disclosure: PH Gross Gaming Revenue Falls 16% to PHP 87.6B</h3>
            <p class="card-dek">Total Q1 2026 GGR PHP 87.6B (-16% YoY). Licensed casinos PHP 44.52B (50.8%), e-gaming PHP 39.90B (-22.4%). The first cleanly post-delinking quarterly read from the regulator quantifies the August 2025 BSP order's structural impact.</p>
            <p class="card-meta">May 29, 2026 &middot; Score 10/10</p>
          </div>
        </a>

        <a href="/articles/senate-anti-online-gambling-act-tulfo-2026.html" class="card">
          <div class="card-img">
            <img src="/hero/senate-anti-online-gambling-act-tulfo-2026.png"
                 alt="Philippine Senate Anti-Online Gambling Act hearing Tulfo Meta"
                 width="640" height="360" loading="lazy">
          </div>
          <div class="card-body">
            <span class="tag tag-news">News</span>
            <h3>Senate Anti-Online Gambling Act Hearing Reopens as Tulfo Pushes Total Ban and Meta No-Shows</h3>
            <p class="card-dek">Senate Committee on Games and Amusement reopened hearings Feb 11, 2026 to debate 7 bills under the Anti-Online Gambling Act umbrella. Chair Sen. Erwin Tulfo backs total ban; SBN 142 most far-reaching. Meta's no-show triggered a show-cause order.</p>
            <p class="card-meta">May 29, 2026 &middot; Score 9/10</p>
          </div>
        </a>

        <a href="/articles/atong-ang-interpol-red-notice-sabungeros-2026.html" class="card">
          <div class="card-img">
            <img src="/hero/atong-ang-interpol-red-notice-sabungeros-2026.png"
                 alt="Interpol Red Notice for Philippine gambling tycoon Atong Ang 2026"
                 width="640" height="360" loading="lazy">
          </div>
          <div class="card-body">
            <span class="tag tag-news">News</span>
            <h3>Interpol Issues Red Notice for Gambling Tycoon Atong Ang Over Sabungeros Disappearances</h3>
            <p class="card-dek">Interpol issued a Red Notice mid-April 2026 for fugitive Philippine gambling tycoon Charlie 'Atong' Ang, principal suspect in the 2021-2022 disappearances of 34+ sabungeros. The DILG has doubled the reward to PHP 20 million as Ang remains in the country.</p>
            <p class="card-meta">May 29, 2026 &middot; Score 9/10</p>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- ANALYSIS & GUIDES -->
  <section class="mb-section" id="analysis-guides" aria-label="Analysis and guides">
    <div class="section-wrap">
      <h2 class="section-title">Analysis &amp; Guides</h2>
      <div class="card-grid-2">

        <a href="/articles/digiplus-market-dominance-pigo-concentration-analysis.html" class="card card-lg">
          <div class="card-img">
            <img src="/hero/digiplus-market-dominance-pigo-concentration-analysis.png"
                 alt="DigiPlus Interactive market dominance Philippine online gambling concentration"
                 width="640" height="360" loading="lazy">
          </div>
          <div class="card-body">
            <span class="tag tag-analysis">Analysis</span>
            <h3>The DigiPlus 50 Percent: What Market Concentration Means for the Philippine Online Gambling Sector</h3>
            <p class="card-dek">DigiPlus controls roughly half of the licensed market — 48 percent of the PHP 154.5B e-games segment in 2024, ~40 percent in H1 2025. What single-operator concentration of this scale means for PAGCOR regulation, for the Senate ban deliberations, and for the structural future of PH online gambling.</p>
            <p class="card-meta">May 29, 2026 &middot; Score 10/10</p>
          </div>
        </a>

        <div class="card-stack">
          <a href="/articles/e-wallet-delinking-six-months-philippines-gaming.html" class="card-row">
            <div class="card-img">
              <img src="/hero/e-wallet-delinking-six-months-philippines-gaming.png"
                   alt="E-wallet delinking impact on Philippine online gaming"
                   width="200" height="150" loading="lazy">
            </div>
            <div class="card-body">
              <span class="tag tag-analysis">Analysis</span>
              <h3>The E-Wallet Delinking Order, Six Months On: What the August 2025 BSP Directive Did</h3>
              <p class="card-meta">May 29, 2026 &middot; Score 10/10</p>
            </div>
          </a>

          <a href="/articles/post-pogo-cambodia-scam-network-structure-2026.html" class="card-row">
            <div class="card-img">
              <img src="/hero/post-pogo-cambodia-scam-network-structure-2026.png"
                   alt="Post-POGO Cambodia scam-casino network structure with OFAC sanctions"
                   width="200" height="150" loading="lazy">
            </div>
            <div class="card-body">
              <span class="tag tag-analysis">Analysis</span>
              <h3>The Post-POGO Cambodia Scam-Casino Nexus: OFAC, Chen Zhi, and What Sihanoukville Looks Like Now</h3>
              <p class="card-meta">May 28, 2026 &middot; Score 10/10</p>
            </div>
          </a>

          <a href="/articles/pagcor-sports-betting-ggr-share-rate-cut-2026.html" class="card-row">
            <div class="card-img">
              <img src="/hero/pagcor-sports-betting-ggr-share-rate-cut-2026.png"
                   alt="PAGCOR sports betting GGR share rate cut from 17.5 to 15 percent"
                   width="200" height="150" loading="lazy">
            </div>
            <div class="card-body">
              <span class="tag tag-analysis">Analysis</span>
              <h3>PAGCOR Cuts Live Sports Betting GGR Share Rate from 17.5% to 15%: Why the Math Changed</h3>
              <p class="card-meta">May 29, 2026 &middot; Score 9/10</p>
            </div>
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- LONGREADS -->
  <section class="mb-section" id="longreads" aria-label="Longreads">
    <div class="section-wrap">
      <h2 class="section-title">Longreads</h2>
      <div class="card-grid">

        <a href="/articles/ceza-aurora-economic-zones-gaming-history-2026.html" class="card">
          <div class="card-img">
            <img src="/hero/ceza-aurora-economic-zones-gaming-history-2026.png"
                 alt="CEZA Cagayan Aurora special economic zones gaming corridor history"
                 width="640" height="360" loading="lazy">
          </div>
          <div class="card-body">
            <span class="tag tag-longread">Longread</span>
            <h3>Inside CEZA and Aurora: The PH Economic Zones That Defined a Gaming Era — and the One That Refused to Host POGOs</h3>
            <p class="card-dek">A reconstructed account of the parallel-regulatory architecture that CEZA and APECO operated under their own founding charters, the CEZA-PAGCOR distinction that the agency still emphasizes, and what EO 74 changed in 2024.</p>
            <p class="card-meta">May 29, 2026 &middot; 17 min read &middot; Score 10/10</p>
          </div>
        </a>

        <a href="/articles/philippine-underground-cash-gambling-post-delinking.html" class="card">
          <div class="card-img">
            <img src="/hero/philippine-underground-cash-gambling-post-delinking.png"
                 alt="Philippine underground cash gambling post-delinking sari-sari store infrastructure"
                 width="640" height="360" loading="lazy">
          </div>
          <div class="card-body">
            <span class="tag tag-longread">Longread</span>
            <h3>After the Bell: The Resurgent Underground of Philippine Cash Gambling</h3>
            <p class="card-dek">Where the displaced quarter of Philippine gambling activity went after the August 2025 BSP delinking order — sari-sari store cash-in infrastructure, the e-sabong shadow that never closed, and the Atong Ang case anchoring the political-economy backdrop.</p>
            <p class="card-meta">May 29, 2026 &middot; 18 min read &middot; Score 10/10</p>
          </div>
        </a>

        <a href="/articles/pasay-to-sihanoukville-worker-migration.html" class="card">
          <div class="card-img">
            <img src="/hero/pasay-to-sihanoukville-worker-migration.png"
                 alt="A POGO worker's migration from Pasay to Sihanoukville"
                 width="640" height="360" loading="lazy">
          </div>
          <div class="card-body">
            <span class="tag tag-longread">Longread</span>
            <h3>From Pasay to Sihanoukville: A POGO Worker's Migration</h3>
            <p class="card-dek">A reconstructed account of one path from Manila to a compound on the Cambodian coast — and what the journey reveals about a regional labor market in transition.</p>
            <p class="card-meta">May 27, 2026 &middot; 22 min read &middot; Score 10/10</p>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- MORE STORIES -->
  <section class="mb-section" id="more-stories" aria-label="More stories">
    <div class="section-wrap">
      <h2 class="section-title">More Stories</h2>
      <div class="card-grid">

        <a href="/articles/arenaplus-nba-philippine-betting-partner-2026.html" class="card">
          <div class="card-img">
            <img src="/hero/arenaplus-nba-philippine-betting-partner-2026.png"
                 alt="ArenaPlus NBA first Philippine official betting partner 2026"
                 width="640" height="360" loading="lazy">
          </div>
          <div class="card-body">
            <span class="tag tag-news">News</span>
            <h3>ArenaPlus Becomes the NBA's First Official Betting Partner in the Philippines</h3>
            <p class="card-dek">DigiPlus's PAGCOR-licensed sportsbook ArenaPlus signed a multiyear collaboration with the NBA on April 27, 2026, becoming the league's first official betting partner in the country. Integrated NBA branding, localized marketing, Playoffs-tied free-to-play games.</p>
            <p class="card-meta">May 29, 2026 &middot; Score 9/10</p>
          </div>
        </a>

        <a href="/articles/digiplus-gameplus-brazil-international-expansion.html" class="card">
          <div class="card-img">
            <img src="/hero/digiplus-gameplus-brazil-international-expansion.png"
                 alt="DigiPlus GamePlus Brazil international expansion BingoPlus 2026"
                 width="640" height="360" loading="lazy">
          </div>
          <div class="card-body">
            <span class="tag tag-news">News</span>
            <h3>DigiPlus's Brazil Bet: Eight Months Into GamePlus, BingoPlus Set to Follow in 2026</h3>
            <p class="card-dek">DigiPlus launched GamePlus in Brazil on September 22, 2025, the company's first international platform. Eight months in, the Brazil operation provides a strategic counterweight to post-delinking domestic earnings pressure.</p>
            <p class="card-meta">May 29, 2026 &middot; Score 8/10</p>
          </div>
        </a>

        <a href="/articles/digiplus-1q-2026-earnings-drop.html" class="card">
          <div class="card-img">
            <img src="/hero/digiplus-1q-2026-earnings-drop.png"
                 alt="DigiPlus Interactive Q1 2026 earnings decline from e-wallet delinking"
                 width="640" height="360" loading="lazy">
          </div>
          <div class="card-body">
            <span class="tag tag-news">News</span>
            <h3>DigiPlus Q1 2026 Net Income Drops 33% to PHP 2.8B as Delinking and Fuel Crisis Weigh</h3>
            <p class="card-dek">The Philippines' dominant online gaming operator posted Q1 2026 net income of PHP 2.82 billion, down 33 percent year on year, on revenue down 25 percent to PHP 17.24 billion. The first cleanly post-delinking comparison quarter.</p>
            <p class="card-meta">May 29, 2026 &middot; Score 9/10</p>
          </div>
        </a>

        <a href="/articles/bloomberry-fy-2025-net-loss.html" class="card">
          <div class="card-img">
            <img src="/hero/bloomberry-fy-2025-net-loss.png"
                 alt="Bloomberry Resorts full-year 2025 net loss illustration"
                 width="640" height="360" loading="lazy">
          </div>
          <div class="card-body">
            <span class="tag tag-news">News</span>
            <h3>Bloomberry Swings to PHP 2.6B Net Loss in 2025 as VIP Slump and MegaFUNalo Costs Bite</h3>
            <p class="card-dek">Solaire operator Bloomberry Resorts swung from a PHP 2.6 billion 2024 profit to a PHP 2.6 billion 2025 loss as VIP weakness, Solaire North full-year opex, and MegaFUNalo online launch costs combined. EBITDA fell 39 percent year on year.</p>
            <p class="card-meta">May 29, 2026 &middot; Score 9/10</p>
          </div>
        </a>

      </div>
    </div>
  </section>

</BaseLayout>
