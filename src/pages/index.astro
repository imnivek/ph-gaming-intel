---
import BaseLayout from '../layouts/BaseLayout.astro';

const siteUrl = 'https://phgamingintel.com';

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      "name": "PH Gaming Intel",
      "url": `${siteUrl}/`,
      "description": "Philippines gaming industry news, regulatory analysis, and data tools.",
      "publisher": { "@id": `${siteUrl}/#organization` },
      "potentialAction": {
        "@type": "SearchAction",
        "target": `${siteUrl}/?s={search_term_string}`,
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@type": "Organization",
      "@id": `${siteUrl}/#organization`,
      "name": "PH Gaming Intel",
      "url": `${siteUrl}/`,
      "logo": { "@type": "ImageObject", "url": `${siteUrl}/logo.png` },
      "sameAs": []
    },
    {
      "@type": "ItemList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "World Cup 2026 Betting Scams Are Already Live: What Filipino Fans Need to Know Before Kickoff", "url": `${siteUrl}/articles/world-cup-2026-betting-scams-philippines-ghost-stadium` },
        { "@type": "ListItem", "position": 2, "name": "How to Watch the 2026 World Cup in the Philippines — Legally, Free and Paid", "url": `${siteUrl}/articles/how-to-watch-world-cup-2026-philippines-legal-free-paid` },
        { "@type": "ListItem", "position": 3, "name": "The World Cup Will Be the Biggest Test Yet of Whether Betting Apps Can Keep Minors Out", "url": `${siteUrl}/articles/world-cup-2026-age-verification-underage-gambling-kyc` },
        { "@type": "ListItem", "position": 4, "name": "48 Teams, 104 Matches, 39 Days: Why the 2026 World Cup Is the Longest Betting-Exposure Window in History", "url": `${siteUrl}/articles/world-cup-2026-48-team-format-betting-exposure-analysis` },
        { "@type": "ListItem", "position": 5, "name": "The Referee Stops Playing: PAGCOR's Decoupling Plan Awaits the Governance Commission's Green Light", "url": `${siteUrl}/articles/pagcor-decoupling-gcg-casino-filipino-2026` },
        { "@type": "ListItem", "position": 6, "name": "DigiPlus Builds an Offshore Hedge as the Home Market Tightens", "url": `${siteUrl}/articles/digiplus-international-hedge-brazil-south-africa-2026` },
        { "@type": "ListItem", "position": 7, "name": "PAGCOR Has Blocked 12,562 Illegal Gambling Sites — and Is Betting the Friction Itself Deters Players", "url": `${siteUrl}/articles/pagcor-illegal-site-blocking-deterrent-2026` },
        { "@type": "ListItem", "position": 8, "name": "PAGCOR's Minimum Guaranteed Fee Takes Effect June 1 — and a New Cap on Player Rebates Comes With It", "url": `${siteUrl}/articles/pagcor-minimum-guaranteed-fee-cashback-cap-june-2026` },
        { "@type": "ListItem", "position": 9, "name": "Why PAGCOR's Cashback Cap Tilts the Table Toward the Giants", "url": `${siteUrl}/articles/pagcor-cashback-cap-market-consolidation-analysis` },
        { "@type": "ListItem", "position": 10, "name": "The Bill That Could Replace the Patchwork: Inside the Philippines' New Comprehensive iGaming Framework", "url": `${siteUrl}/articles/philippine-comprehensive-igaming-bill-2026-framework` },
        { "@type": "ListItem", "position": 11, "name": "DigiPlus Leads Launch of PlaySafe Alliance as PAGCOR Doubles Down on Responsible Gaming", "url": `${siteUrl}/articles/digiplus-playsafe-alliance-launch-2026` },
        { "@type": "ListItem", "position": 12, "name": "Text Blasters: The Post-POGO Scam Hardware the PNP Is Now Hunting", "url": `${siteUrl}/articles/text-blaster-black-market-post-pogo-2026` },
        { "@type": "ListItem", "position": 13, "name": "How to Spot an Illegal Betting Site During the World Cup: A Philippine Player's Checklist", "url": `${siteUrl}/articles/spot-illegal-betting-sites-world-cup-2026-philippines` },
        { "@type": "ListItem", "position": 14, "name": "Do You Pay Tax on Betting Winnings in the Philippines? A World Cup Explainer", "url": `${siteUrl}/articles/betting-winnings-tax-philippines-world-cup-2026` },
        { "@type": "ListItem", "position": 15, "name": "Live (In-Play) Betting Explained: The Product the World Cup Is Built to Sell", "url": `${siteUrl}/articles/live-in-play-betting-explained-world-cup-2026` },
        { "@type": "ListItem", "position": 16, "name": "How to Bet on the 2026 FIFA World Cup Legally in the Philippines: A PAGCOR-Licensed Sportsbook Guide", "url": `${siteUrl}/articles/how-to-bet-fifa-world-cup-2026-philippines-pagcor.html` },
        { "@type": "ListItem", "position": 17, "name": "PAGCOR-Licensed Sportsbooks Brace for a World Cup Betting Surge", "url": `${siteUrl}/articles/pagcor-sportsbooks-world-cup-2026-betting-surge.html` },
        { "@type": "ListItem", "position": 18, "name": "Will the World Cup Move the Needle on Philippine Sports Betting GGR? Doing the Math on the 15% Rate", "url": `${siteUrl}/articles/world-cup-2026-philippine-sports-betting-ggr-analysis.html` },
        { "@type": "ListItem", "position": 19, "name": "Football Betting Odds Explained: How to Read World Cup Markets Without Fooling Yourself", "url": `${siteUrl}/articles/football-betting-odds-explained-world-cup-2026.html` },
        { "@type": "ListItem", "position": 20, "name": "Responsible Betting During the World Cup: Deposit Limits, Self-Exclusion, and the PAGCOR Helpline", "url": `${siteUrl}/articles/responsible-betting-world-cup-2026-pagcor-self-exclusion.html` },
        { "@type": "ListItem", "position": 21, "name": "Inside CEZA and Aurora: The Philippine Economic Zones That Defined a Gaming Era — and the One That Refused to Host POGOs", "url": `${siteUrl}/articles/ceza-aurora-economic-zones-gaming-history-2026.html` },
        { "@type": "ListItem", "position": 22, "name": "PAGCOR Q1 2026 Official Disclosure: Philippine Gross Gaming Revenue Falls 16% to PHP 87.6B", "url": `${siteUrl}/articles/pagcor-q1-2026-official-ggr-disclosure.html` },
        { "@type": "ListItem", "position": 23, "name": "Senate Anti-Online Gambling Act Hearing Reopens as Tulfo Pushes Total Ban and Meta No-Shows", "url": `${siteUrl}/articles/senate-anti-online-gambling-act-tulfo-2026.html` },
        { "@type": "ListItem", "position": 24, "name": "The DigiPlus 50 Percent: What Market Concentration Means for the Philippine Online Gambling Sector", "url": `${siteUrl}/articles/digiplus-market-dominance-pigo-concentration-analysis.html` },
        { "@type": "ListItem", "position": 25, "name": "PAGCOR Cuts Live Sports Betting GGR Share Rate from 17.5% to 15%: Why the Math Changed", "url": `${siteUrl}/articles/pagcor-sports-betting-ggr-share-rate-cut-2026.html` },
        { "@type": "ListItem", "position": 26, "name": "After the Bell: The Resurgent Underground of Philippine Cash Gambling", "url": `${siteUrl}/articles/philippine-underground-cash-gambling-post-delinking.html` },
        { "@type": "ListItem", "position": 27, "name": "Interpol Issues Red Notice for Philippine Gambling Tycoon Atong Ang Over Sabungeros Disappearances", "url": `${siteUrl}/articles/atong-ang-interpol-red-notice-sabungeros-2026.html` },
        { "@type": "ListItem", "position": 28, "name": "ArenaPlus Becomes the NBA's First Official Betting Partner in the Philippines", "url": `${siteUrl}/articles/arenaplus-nba-philippine-betting-partner-2026.html` },
        { "@type": "ListItem", "position": 29, "name": "DigiPlus's Brazil Bet: Eight Months Into GamePlus, BingoPlus Set to Follow in 2026", "url": `${siteUrl}/articles/digiplus-gameplus-brazil-international-expansion.html` },
        { "@type": "ListItem", "position": 30, "name": "The E-Wallet Delinking Order, Six Months On: What the August 2025 BSP Directive Did to Philippine Online Gaming", "url": `${siteUrl}/articles/e-wallet-delinking-six-months-philippines-gaming.html` },
        { "@type": "ListItem", "position": 31, "name": "Bloomberry Swings to PHP 2.6B Net Loss in 2025 as VIP Slump and MegaFUNalo Costs Bite", "url": `${siteUrl}/articles/bloomberry-fy-2025-net-loss.html` },
        { "@type": "ListItem", "position": 32, "name": "DigiPlus Q1 2026 Net Income Drops 33% to PHP 2.8B as Delinking and Fuel Crisis Weigh", "url": `${siteUrl}/articles/digiplus-1q-2026-earnings-drop.html` },
        { "@type": "ListItem", "position": 33, "name": "PAGCOR Launches 24/7 National Problem Gambling Helpline in Pasay City", "url": `${siteUrl}/articles/pagcor-npgh-helpline-launch-2026.html` },
        { "@type": "ListItem", "position": 34, "name": "The Post-POGO Cambodia Scam-Casino Nexus: OFAC, Chen Zhi, and What Sihanoukville Looks Like Now", "url": `${siteUrl}/articles/post-pogo-cambodia-scam-network-structure-2026.html` },
        { "@type": "ListItem", "position": 35, "name": "PAGCOR Sets August 1 Deadline to Decommission Non-Compliant B2B Gaming Systems", "url": `${siteUrl}/articles/pagcor-b2b-system-decommissioning-august-2026.html` },
        { "@type": "ListItem", "position": 36, "name": "Cambodia Revokes Zhong Huawei Casino License as Sihanoukville Crackdown Hits Eight Operators", "url": `${siteUrl}/articles/cambodia-revokes-zhong-huawei-casino-license.html` },
        { "@type": "ListItem", "position": 37, "name": "BingoPlus Reports PHP 2.25 Trillion in Cumulative Payouts at 2026 Anniversary", "url": `${siteUrl}/articles/bingoplus-anniversary-2026-payouts.html` },
        { "@type": "ListItem", "position": 38, "name": "From Pasay to Sihanoukville: A POGO Worker's Migration", "url": `${siteUrl}/articles/pasay-to-sihanoukville-worker-migration.html` },
        { "@type": "ListItem", "position": 39, "name": "Senate Bill 2580 in Plain English: The PAGCOR Reform That Wasn't", "url": `${siteUrl}/articles/senate-bill-2580-pagcor-reform-failed.html` },
        { "@type": "ListItem", "position": 40, "name": "GCash Casino Partnerships Hit 47 in Q2 2026 as Cashless Push Accelerates", "url": `${siteUrl}/articles/gcash-casino-partnerships-q2-2026.html` },
        { "@type": "ListItem", "position": 41, "name": "Why Cambodia Won the POGO Refugees: A Geopolitical Read", "url": `${siteUrl}/articles/why-cambodia-won-pogo-refugees.html` },
        { "@type": "ListItem", "position": 42, "name": "Manila Bay at 4 AM: The Hidden Shift Change Inside PH Integrated Resorts", "url": `${siteUrl}/articles/manila-bay-4am-ir-workers.html` },
        { "@type": "ListItem", "position": 43, "name": "Cambodia Gaming License Framework: Three-Tier System Targets Former POGO Operators", "url": `${siteUrl}/articles/cambodia-gaming-license-pogo.html` },
        { "@type": "ListItem", "position": 44, "name": "PAGCOR Privatization Bill SB 2814 Advances in Senate Committee", "url": `${siteUrl}/articles/pagcor-privatization-bill.html` },
        { "@type": "ListItem", "position": 45, "name": "Bloomberry Resorts Q1 2026: Revenue Down 18% as VIP Rolling Chip Drops 26%", "url": `${siteUrl}/articles/bloomberry-q1-2026-solaire.html` },
        { "@type": "ListItem", "position": 46, "name": "PIGO vs e-Games: The Regulatory Maze Mapped", "url": `${siteUrl}/articles/pigo-vs-egames-regulatory-maze.html` },
        { "@type": "ListItem", "position": 47, "name": "Best PAGCOR Licensed Online Casinos Philippines 2026", "url": `${siteUrl}/articles/pagcor-licensed-casinos-guide-2026.html` },
        { "@type": "ListItem", "position": 48, "name": "Philippine GGR Falls 15.8% to $1.42bn in Q1 2026", "url": `${siteUrl}/articles/philippine-ggr-falls-q1-2026-pagcor.html` },
        { "@type": "ListItem", "position": 49, "name": "Okada Play Commercial Launch: PhilWeb and Tiger Resort Go Digital", "url": `${siteUrl}/articles/okada-play-commercial-launch.html` },
        { "@type": "ListItem", "position": 50, "name": "Altenar Powers DigiPlus ArenaPlus Sportsbook in the Philippines", "url": `${siteUrl}/articles/altenar-arenaplus-sportsbook.html` }
      ]
    }
  ]
};
---

<BaseLayout
  title="PH Gaming Intel — Philippines Gaming Industry News & Analysis"
  description="PH Gaming Intel covers the Philippines gaming industry with in-depth news, regulatory analysis, PAGCOR updates, POGO tracking, and IR resort coverage."
  activePage="news"
  jsonLd={jsonLd}
>

  <!-- HERO — Featured Story -->
  <section class="hero-featured" aria-label="Featured story">
    <img src="/hero/pasay-to-sihanoukville-worker-migration.png"
         alt="A POGO worker's migration from Pasay to Sihanoukville — layered map and silhouettes"
         width="1920" height="1080" loading="eager">
    <div class="overlay">
      <div class="overlay-inner">
        <span class="tag tag-longread">Longread</span>
        <h1>From Pasay to Sihanoukville: A POGO Worker's Migration</h1>
        <p class="dek">When the Philippine offshore gaming industry was shut down in 2024, the buildings emptied. The workers had to go somewhere. A reconstructed account of one path — and what the journey reveals about a regional labor market in transition.</p>
        <p class="meta">May 27, 2026 &middot; 22 min read &middot; Editorial Score 10/10</p>
        <a href="/articles/pasay-to-sihanoukville-worker-migration.html" style="display:inline-block;margin-top:16px;padding:12px 28px;border-radius:8px;background:var(--gold);color:var(--dark);font-family:var(--font-ui);font-size:14px;font-weight:700;letter-spacing:.5px;transition:background .2s;">Read the Full Story</a>
      </div>
    </div>
  </section>

  <!-- LATEST NEWS -->
  <section class="mt-section mb-section" id="latest-news" aria-label="Latest news">
    <div class="section-wrap">
      <h2 class="section-title">Latest News</h2>
      <div class="card-grid">

        <a href="/articles/world-cup-2026-betting-scams-philippines-ghost-stadium" class="card">
          <div class="card-img">
            <img src="/hero/world-cup-2026-betting-scams-philippines-ghost-stadium.png"
                 alt="World Cup 2026 online betting and ticketing scam networks targeting Filipino fans"
                 width="640" height="360" loading="lazy">
          </div>
          <div class="card-body">
            <span class="tag tag-news">News</span>
            <h3>World Cup 2026 Betting Scams Are Already Live: What Filipino Fans Need to Know Before Kickoff</h3>
            <p class="card-dek">Researchers mapped 4,300+ fake FIFA domains, a Chinese-speaking group running pixel-perfect FIFA clones, fake betting sites harvesting passport scans, and pirate streams that install malware — and the FBI has issued a warning. Days from kickoff, here's the threat map for Filipino fans and the concrete steps to stay safe.</p>
            <p class="card-meta">June 5, 2026 &middot; Score 9/10</p>
          </div>
        </a>

        <a href="/articles/pagcor-decoupling-gcg-casino-filipino-2026" class="card">
          <div class="card-img">
            <img src="/hero/pagcor-decoupling-gcg-casino-filipino-2026.png"
                 alt="PAGCOR decoupling its regulator and operator roles, awaiting the Governance Commission's recommendation"
                 width="640" height="360" loading="lazy">
          </div>
          <div class="card-body">
            <span class="tag tag-news">News</span>
            <h3>The Referee Stops Playing: PAGCOR's Decoupling Plan Awaits the Governance Commission's Green Light</h3>
            <p class="card-dek">PAGCOR is moving to split the two jobs it has held since 1976 — regulating gambling and running its own Casino Filipino chain. The decoupling now awaits the GCG's recommendation, expected within weeks, before going to the Office of the President. A privatized Casino Filipino could raise PHP 30–50B. The administrative route to the split Senate Bill 2814 would also legislate.</p>
            <p class="card-meta">June 5, 2026 &middot; Score 9/10</p>
          </div>
        </a>

        <a href="/articles/pagcor-illegal-site-blocking-deterrent-2026" class="card">
          <div class="card-img">
            <img src="/hero/pagcor-illegal-site-blocking-deterrent-2026.png"
                 alt="PAGCOR blocking illegal online gambling sites with an AI-powered detection tool"
                 width="640" height="360" loading="lazy">
          </div>
          <div class="card-body">
            <span class="tag tag-news">News</span>
            <h3>PAGCOR Has Blocked 12,562 Illegal Gambling Sites — and Is Betting the Friction Itself Deters Players</h3>
            <p class="card-dek">PAGCOR says 93.8% of the 13,399 illegal sites it has flagged are now blocked, up from 74% two months earlier, driven by an AI detection tool. The agency admits it can't kill every site — it's banking on the repeated friction of blocking to steer casual bettors toward licensed operators, just as World Cup search traffic spikes.</p>
            <p class="card-meta">June 5, 2026 &middot; Score 8/10</p>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- SPORTS BETTING — World Cup 2026 -->
  <section class="mb-section" id="sports-betting" aria-label="Sports betting and the World Cup">
    <div class="section-wrap">
      <h2 class="section-title">Sports Betting &middot; World Cup 2026 &nbsp;<a href="/sports-betting" style="font-size:14px;font-family:var(--font-ui);font-weight:600;letter-spacing:.5px;color:var(--gold);text-transform:uppercase;vertical-align:middle;">View all &rsaquo;</a></h2>
      <div class="card-grid-2">

        <a href="/articles/how-to-watch-world-cup-2026-philippines-legal-free-paid" class="card card-lg">
          <div class="card-img">
            <img src="/hero/how-to-watch-world-cup-2026-philippines-legal-free-paid.png"
                 alt="Legal ways to watch the 2026 World Cup in the Philippines, free and paid"
                 width="640" height="360" loading="lazy">
          </div>
          <div class="card-body">
            <span class="tag tag-guide">Guide</span>
            <h3>How to Watch the 2026 World Cup in the Philippines — Legally, Free and Paid</h3>
            <p class="card-dek">Officially distributed through Aleph Group: BlastTV carries every match on pay-per-view (FIFA World Cup Pass ~PHP 1,999), with select games free on Aleph Arena YouTube, GMA, and TV5. With kickoff around 3 AM Manila time, chasing unofficial streams is exactly what malware operators count on. The licensed way to watch all 104 matches — and the traps to avoid.</p>
            <p class="card-meta">June 5, 2026 &middot; 7 min read</p>
          </div>
        </a>

        <div class="card-stack">
          <a href="/articles/world-cup-2026-age-verification-underage-gambling-kyc" class="card-row">
            <div class="card-img">
              <img src="/hero/world-cup-2026-age-verification-underage-gambling-kyc.png"
                   alt="Age and identity verification keeping minors out of online betting during the World Cup"
                   width="200" height="150" loading="lazy">
            </div>
            <div class="card-body">
              <span class="tag tag-news">News</span>
              <h3>The World Cup Will Be the Biggest Test Yet of Whether Betting Apps Can Keep Minors Out</h3>
              <p class="card-meta">June 5, 2026 &middot; 8 min read</p>
            </div>
          </a>

          <a href="/articles/world-cup-2026-48-team-format-betting-exposure-analysis" class="card-row">
            <div class="card-img">
              <img src="/hero/world-cup-2026-48-team-format-betting-exposure-analysis.png"
                   alt="The expanded 48-team 2026 World Cup as the longest betting-exposure window in history"
                   width="200" height="150" loading="lazy">
            </div>
            <div class="card-body">
              <span class="tag tag-analysis">Analysis</span>
              <h3>48 Teams, 104 Matches, 39 Days: The Longest Betting-Exposure Window in History</h3>
              <p class="card-meta">June 5, 2026 &middot; 9 min read</p>
            </div>
          </a>

          <a href="/tools/betting-odds-calculator" class="card-row">
            <div class="card-img">
              <img src="/hero/betting-odds-calculator.png"
                   alt="Free betting odds and implied probability calculator tool"
                   width="200" height="150" loading="lazy">
            </div>
            <div class="card-body">
              <span class="tag" style="background:var(--gold);color:var(--dark);">Tool</span>
              <h3>Free Tool: Betting Odds &amp; Implied Probability Calculator</h3>
              <p class="card-meta">Interactive &middot; See the house margin</p>
            </div>
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ANALYSIS & GUIDES -->
  <section class="mb-section" id="analysis-guides" aria-label="Analysis and guides">
    <div class="section-wrap">
      <h2 class="section-title">Analysis &amp; Guides</h2>
      <div class="card-grid-2">

        <a href="/articles/digiplus-international-hedge-brazil-south-africa-2026" class="card card-lg">
          <div class="card-img">
            <img src="/hero/digiplus-international-hedge-brazil-south-africa-2026.png"
                 alt="DigiPlus diversifying from the Philippines toward Brazil and South Africa markets"
                 width="640" height="360" loading="lazy">
          </div>
          <div class="card-body">
            <span class="tag tag-analysis">Analysis</span>
            <h3>DigiPlus Builds an Offshore Hedge as the Home Market Tightens</h3>
            <p class="card-dek">DigiPlus owns half a Philippine market that is shrinking, capped, and under a live ban threat at once. Its answer is to push the other way: a Brazil relaunch by end-June, a South Africa launch targeted for 2027, a new president to drive it, and margin work after a 33% Q1 profit drop. Read as what it is — a deliberate hedge against the risk of being a giant in one tightening market.</p>
            <p class="card-meta">June 5, 2026 &middot; Score 9/10</p>
          </div>
        </a>

        <div class="card-stack">
          <a href="/articles/pagcor-cashback-cap-market-consolidation-analysis" class="card-row">
            <div class="card-img">
              <img src="/hero/pagcor-cashback-cap-market-consolidation-analysis.png"
                   alt="Market consolidation in Philippine online gaming following PAGCOR's cashback cap"
                   width="200" height="150" loading="lazy">
            </div>
            <div class="card-body">
              <span class="tag tag-analysis">Analysis</span>
              <h3>Why PAGCOR's Cashback Cap Tilts the Table Toward the Giants</h3>
              <p class="card-meta">June 4, 2026 &middot; Score 9/10</p>
            </div>
          </a>

          <a href="/articles/philippine-comprehensive-igaming-bill-2026-framework" class="card-row">
            <div class="card-img">
              <img src="/hero/philippine-comprehensive-igaming-bill-2026-framework.png"
                   alt="Philippines drafting a comprehensive iGaming legislative framework in 2026"
                   width="200" height="150" loading="lazy">
            </div>
            <div class="card-body">
              <span class="tag tag-analysis">Analysis</span>
              <h3>The Bill That Could Replace the Patchwork: Inside the New Comprehensive iGaming Framework</h3>
              <p class="card-meta">June 4, 2026 &middot; Score 9/10</p>
            </div>
          </a>

          <a href="/articles/digiplus-market-dominance-pigo-concentration-analysis.html" class="card-row">
            <div class="card-img">
              <img src="/hero/digiplus-market-dominance-pigo-concentration-analysis.png"
                   alt="DigiPlus Interactive market dominance Philippine online gambling concentration"
                   width="200" height="150" loading="lazy">
            </div>
            <div class="card-body">
              <span class="tag tag-analysis">Analysis</span>
              <h3>The DigiPlus 50 Percent: What Market Concentration Means for PH Online Gambling</h3>
              <p class="card-meta">May 29, 2026 &middot; Score 10/10</p>
            </div>
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- LONGREADS -->
  <section class="mb-section" id="longreads" aria-label="Longreads">
    <div class="section-wrap">
      <h2 class="section-title">Longreads</h2>
      <div class="card-grid">

        <a href="/articles/ceza-aurora-economic-zones-gaming-history-2026.html" class="card">
          <div class="card-img">
            <img src="/hero/ceza-aurora-economic-zones-gaming-history-2026.png"
                 alt="CEZA Cagayan Aurora special economic zones gaming corridor history"
                 width="640" height="360" loading="lazy">
          </div>
          <div class="card-body">
            <span class="tag tag-longread">Longread</span>
            <h3>Inside CEZA and Aurora: The PH Economic Zones That Defined a Gaming Era — and the One That Refused to Host POGOs</h3>
            <p class="card-dek">A reconstructed account of the parallel-regulatory architecture that CEZA and APECO operated under their own founding charters, the CEZA-PAGCOR distinction that the agency still emphasizes, and what EO 74 changed in 2024.</p>
            <p class="card-meta">May 29, 2026 &middot; 17 min read &middot; Score 10/10</p>
          </div>
        </a>

        <a href="/articles/philippine-underground-cash-gambling-post-delinking.html" class="card">
          <div class="card-img">
            <img src="/hero/philippine-underground-cash-gambling-post-delinking.png"
                 alt="Philippine underground cash gambling post-delinking sari-sari store infrastructure"
                 width="640" height="360" loading="lazy">
          </div>
