---
import BaseLayout from '../layouts/BaseLayout.astro';

const siteUrl = 'https://phgamingintel.com';

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      "name": "PH Gaming Intel",
      "url": `${siteUrl}/`,
      "description": "Philippines gaming industry news, regulatory analysis, and data tools.",
      "publisher": { "@id": `${siteUrl}/#organization` },
      "potentialAction": {
        "@type": "SearchAction",
        "target": `${siteUrl}/?s={search_term_string}`,
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@type": "Organization",
      "@id": `${siteUrl}/#organization`,
      "name": "PH Gaming Intel",
      "url": `${siteUrl}/`,
      "logo": { "@type": "ImageObject", "url": `${siteUrl}/logo.png` },
      "sameAs": []
    },
    {
      "@type": "ItemList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "The E-Wallet Delinking Order, Six Months On: What the August 2025 BSP Directive Did to Philippine Online Gaming", "url": `${siteUrl}/articles/e-wallet-delinking-six-months-philippines-gaming.html` },
        { "@type": "ListItem", "position": 2, "name": "Bloomberry Swings to PHP 2.6B Net Loss in 2025 as VIP Slump and MegaFUNalo Costs Bite", "url": `${siteUrl}/articles/bloomberry-fy-2025-net-loss.html` },
        { "@type": "ListItem", "position": 3, "name": "DigiPlus Q1 2026 Net Income Drops 33% to PHP 2.8B as Delinking and Fuel Crisis Weigh", "url": `${siteUrl}/articles/digiplus-1q-2026-earnings-drop.html` },
        { "@type": "ListItem", "position": 4, "name": "PAGCOR Launches 24/7 National Problem Gambling Helpline in Pasay City", "url": `${siteUrl}/articles/pagcor-npgh-helpline-launch-2026.html` },
        { "@type": "ListItem", "position": 5, "name": "The Post-POGO Cambodia Scam-Casino Nexus: OFAC, Chen Zhi, and What Sihanoukville Looks Like Now", "url": `${siteUrl}/articles/post-pogo-cambodia-scam-network-structure-2026.html` },
        { "@type": "ListItem", "position": 6, "name": "PAGCOR Sets August 1 Deadline to Decommission Non-Compliant B2B Gaming Systems", "url": `${siteUrl}/articles/pagcor-b2b-system-decommissioning-august-2026.html` },
        { "@type": "ListItem", "position": 7, "name": "Cambodia Revokes Zhong Huawei Casino License as Sihanoukville Crackdown Hits Eight Operators", "url": `${siteUrl}/articles/cambodia-revokes-zhong-huawei-casino-license.html` },
        { "@type": "ListItem", "position": 8, "name": "BingoPlus Reports PHP 2.25 Trillion in Cumulative Payouts at 2026 Anniversary", "url": `${siteUrl}/articles/bingoplus-anniversary-2026-payouts.html` },
        { "@type": "ListItem", "position": 9, "name": "From Pasay to Sihanoukville: A POGO Worker's Migration", "url": `${siteUrl}/articles/pasay-to-sihanoukville-worker-migration.html` },
        { "@type": "ListItem", "position": 10, "name": "Senate Bill 2580 in Plain English: The PAGCOR Reform That Wasn't", "url": `${siteUrl}/articles/senate-bill-2580-pagcor-reform-failed.html` },
        { "@type": "ListItem", "position": 11, "name": "GCash Casino Partnerships Hit 47 in Q2 2026 as Cashless Push Accelerates", "url": `${siteUrl}/articles/gcash-casino-partnerships-q2-2026.html` },
        { "@type": "ListItem", "position": 12, "name": "Why Cambodia Won the POGO Refugees: A Geopolitical Read", "url": `${siteUrl}/articles/why-cambodia-won-pogo-refugees.html` },
        { "@type": "ListItem", "position": 13, "name": "Manila Bay at 4 AM: The Hidden Shift Change Inside PH Integrated Resorts", "url": `${siteUrl}/articles/manila-bay-4am-ir-workers.html` },
        { "@type": "ListItem", "position": 14, "name": "Cambodia Gaming License Framework: Three-Tier System Targets Former POGO Operators", "url": `${siteUrl}/articles/cambodia-gaming-license-pogo.html` },
        { "@type": "ListItem", "position": 15, "name": "PAGCOR Privatization Bill SB 2814 Advances in Senate Committee", "url": `${siteUrl}/articles/pagcor-privatization-bill.html` },
        { "@type": "ListItem", "position": 16, "name": "Bloomberry Resorts Q1 2026: Revenue Down 18% as VIP Rolling Chip Drops 26%", "url": `${siteUrl}/articles/bloomberry-q1-2026-solaire.html` },
        { "@type": "ListItem", "position": 17, "name": "PIGO vs e-Games: The Regulatory Maze Mapped", "url": `${siteUrl}/articles/pigo-vs-egames-regulatory-maze.html` },
        { "@type": "ListItem", "position": 18, "name": "Best PAGCOR Licensed Online Casinos Philippines 2026", "url": `${siteUrl}/articles/pagcor-licensed-casinos-guide-2026.html` },
        { "@type": "ListItem", "position": 19, "name": "Philippine GGR Falls 15.8% to $1.42bn in Q1 2026", "url": `${siteUrl}/articles/philippine-ggr-falls-q1-2026-pagcor.html` },
        { "@type": "ListItem", "position": 20, "name": "Okada Play Commercial Launch: PhilWeb and Tiger Resort Go Digital", "url": `${siteUrl}/articles/okada-play-commercial-launch.html` },
        { "@type": "ListItem", "position": 21, "name": "Altenar Powers DigiPlus ArenaPlus Sportsbook in the Philippines", "url": `${siteUrl}/articles/altenar-arenaplus-sportsbook.html` }
      ]
    }
  ]
};
---

<BaseLayout
  title="PH Gaming Intel — Philippines Gaming Industry News & Analysis"
  description="PH Gaming Intel covers the Philippines gaming industry with in-depth news, regulatory analysis, PAGCOR updates, POGO tracking, and IR resort coverage."
  activePage="news"
  jsonLd={jsonLd}
>

  <!-- HERO — Featured Story -->
  <section class="hero-featured" aria-label="Featured story">
    <img src="/hero/pasay-to-sihanoukville-worker-migration.png"
         alt="A POGO worker's migration from Pasay to Sihanoukville — layered map and silhouettes"
         width="1920" height="1080" loading="eager">
    <div class="overlay">
      <div class="overlay-inner">
        <span class="tag tag-longread">Longread</span>
        <h1>From Pasay to Sihanoukville: A POGO Worker's Migration</h1>
        <p class="dek">When the Philippine offshore gaming industry was shut down in 2024, the buildings emptied. The workers had to go somewhere. A reconstructed account of one path — and what the journey reveals about a regional labor market in transition.</p>
        <p class="meta">May 27, 2026 &middot; 22 min read &middot; Editorial Score 10/10</p>
        <a href="/articles/pasay-to-sihanoukville-worker-migration.html" style="display:inline-block;margin-top:16px;padding:12px 28px;border-radius:8px;background:var(--gold);color:var(--dark);font-family:var(--font-ui);font-size:14px;font-weight:700;letter-spacing:.5px;transition:background .2s;">Read the Full Story</a>
      </div>
    </div>
  </section>

  <!-- LATEST NEWS -->
  <section class="mt-section mb-section" id="latest-news" aria-label="Latest news">
    <div class="section-wrap">
      <h2 class="section-title">Latest News</h2>
      <div class="card-grid">

        <a href="/articles/bloomberry-fy-2025-net-loss.html" class="card">
          <div class="card-img">
            <img src="/hero/bloomberry-fy-2025-net-loss.png"
                 alt="Bloomberry Resorts full-year 2025 net loss illustration"
                 width="640" height="360" loading="lazy">
          </div>
          <div class="card-body">
            <span class="tag tag-news">News</span>
            <h3>Bloomberry Swings to PHP 2.6B Net Loss in 2025 as VIP Slump and MegaFUNalo Costs Bite</h3>
            <p class="card-dek">Solaire operator Bloomberry Resorts swung from a PHP 2.6 billion 2024 profit to a PHP 2.6 billion 2025 loss as VIP weakness, Solaire North full-year opex, and MegaFUNalo online launch costs combined. EBITDA fell 39 percent year on year.</p>
            <p class="card-meta">May 29, 2026 &middot; Score 9/10</p>
          </div>
        </a>

        <a href="/articles/digiplus-1q-2026-earnings-drop.html" class="card">
          <div class="card-img">
            <img src="/hero/digiplus-1q-2026-earnings-drop.png"
                 alt="DigiPlus Interactive Q1 2026 earnings decline from e-wallet delinking"
                 width="640" height="360" loading="lazy">
          </div>
          <div class="card-body">
            <span class="tag tag-news">News</span>
            <h3>DigiPlus Q1 2026 Net Income Drops 33% to PHP 2.8B as Delinking and Fuel Crisis Weigh</h3>
            <p class="card-dek">The Philippines' dominant online gaming operator posted Q1 2026 net income of PHP 2.82 billion, down 33 percent year on year, on revenue down 25 percent to PHP 17.24 billion. The first cleanly post-delinking comparison quarter.</p>
            <p class="card-meta">May 29, 2026 &middot; Score 9/10</p>
          </div>
        </a>

        <a href="/articles/pagcor-npgh-helpline-launch-2026.html" class="card">
          <div class="card-img">
            <img src="/hero/pagcor-npgh-helpline-launch-2026.png"
                 alt="PAGCOR National Problem Gambling Helpline launch May 2026"
                 width="640" height="360" loading="lazy">
          </div>
          <div class="card-body">
            <span class="tag tag-news">News</span>
            <h3>PAGCOR Launches 24/7 National Problem Gambling Helpline in Pasay City</h3>
            <p class="card-dek">PAGCOR launched the 24-hour National Problem Gambling Helpline on May 26, 2026, the first round-the-clock dedicated gambling-problem service in the Philippines. The line (02) 8248-9568 is run by 12 para-counselors with Seagulls Flock Organization Inc.</p>
            <p class="card-meta">May 29, 2026 &middot; Score 8/10</p>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- ANALYSIS & GUIDES -->
  <section class="mb-section" id="analysis-guides" aria-label="Analysis and guides">
    <div class="section-wrap">
      <h2 class="section-title">Analysis &amp; Guides</h2>
      <div class="card-grid-2">

        <a href="/articles/e-wallet-delinking-six-months-philippines-gaming.html" class="card card-lg">
          <div class="card-img">
            <img src="/hero/e-wallet-delinking-six-months-philippines-gaming.png"
                 alt="E-wallet delinking impact on Philippine online gaming six months after BSP directive"
                 width="640" height="360" loading="lazy">
          </div>
          <div class="card-body">
            <span class="tag tag-analysis">Analysis</span>
            <h3>The E-Wallet Delinking Order, Six Months On: What the August 2025 BSP Directive Did to Philippine Online Gaming</h3>
            <p class="card-dek">An analytic read of the structural impact of the August 14, 2025 BSP directive: a 50 percent immediate transaction decline, a 49 percent drop in PAGCOR online gaming income, DigiPlus revenue -25 percent in Q1 2026, Bloomberry EBITDA -39 percent for FY 2025. What changed, what didn't, and what the new equilibrium looks like.</p>
            <p class="card-meta">May 29, 2026 &middot; Score 10/10</p>
          </div>
        </a>

        <div class="card-stack">
          <a href="/articles/post-pogo-cambodia-scam-network-structure-2026.html" class="card-row">
            <div class="card-img">
              <img src="/hero/post-pogo-cambodia-scam-network-structure-2026.png"
                   alt="Post-POGO Cambodia scam-casino network structure with OFAC sanctions"
                   width="200" height="150" loading="lazy">
            </div>
            <div class="card-body">
              <span class="tag tag-analysis">Analysis</span>
              <h3>The Post-POGO Cambodia Scam-Casino Nexus: OFAC, Chen Zhi, and What Sihanoukville Looks Like Now</h3>
              <p class="card-meta">May 28, 2026 &middot; Score 10/10</p>
            </div>
          </a>

          <a href="/articles/why-cambodia-won-pogo-refugees.html" class="card-row">
            <div class="card-img">
              <img src="/hero/why-cambodia-won-pogo-refugees-geopolitical.png"
                   alt="Map illustration of Southeast Asian gaming jurisdictions with Cambodia highlighted"
                   width="200" height="150" loading="lazy">
            </div>
            <div class="card-body">
              <span class="tag tag-analysis">Analysis</span>
              <h3>Why Cambodia Won the POGO Refugees: A Geopolitical Read</h3>
              <p class="card-meta">May 26, 2026 &middot; Score 10/10</p>
            </div>
          </a>

          <a href="/articles/senate-bill-2580-pagcor-reform-failed.html" class="card-row">
            <div class="card-img">
              <img src="/hero/senate-bill-2580-pagcor-reform-failed.png"
                   alt="Shelved Senate bill folder representing failed PAGCOR reform"
                   width="200" height="150" loading="lazy">
            </div>
            <div class="card-body">
              <span class="tag tag-analysis">Analysis</span>
              <h3>Senate Bill 2580 in Plain English: The PAGCOR Reform That Wasn't</h3>
              <p class="card-meta">May 27, 2026 &middot; Score 9/10</p>
            </div>
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- LONGREADS -->
  <section class="mb-section" id="longreads" aria-label="Longreads">
    <div class="section-wrap">
      <h2 class="section-title">Longreads</h2>
      <div class="card-grid">

        <a href="/articles/pasay-to-sihanoukville-worker-migration.html" class="card">
          <div class="card-img">
            <img src="/hero/pasay-to-sihanoukville-worker-migration.png"
                 alt="A POGO worker's migration from Pasay to Sihanoukville"
                 width="640" height="360" loading="lazy">
          </div>
          <div class="card-body">
            <span class="tag tag-longread">Longread</span>
            <h3>From Pasay to Sihanoukville: A POGO Worker's Migration</h3>
            <p class="card-dek">A reconstructed account of one path from Manila to a compound on the Cambodian coast — and what the journey reveals about a regional labor market in transition.</p>
            <p class="card-meta">May 27, 2026 &middot; 22 min read &middot; Score 10/10</p>
          </div>
        </a>

        <a href="/articles/manila-bay-4am-ir-workers.html" class="card">
          <div class="card-img">
            <img src="/hero/manila-bay-4am-hidden-shift-ir-workers.png"
                 alt="Manila Bay waterfront at 4 AM — integrated resort workers"
                 width="640" height="360" loading="lazy">
          </div>
          <div class="card-body">
            <span class="tag tag-longread">Longread</span>
            <h3>Manila Bay at 4 AM: The Hidden Shift Change Inside PH Integrated Resorts</h3>
            <p class="card-dek">When the high rollers leave and the floor lights dim, a different kind of labor begins. An on-the-ground investigation into the workforce that powers Entertainment City around the clock.</p>
            <p class="card-meta">May 25, 2026 &middot; 18 min read &middot; Score 10/10</p>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- MORE STORIES -->
  <section class="mb-section" id="more-stories" aria-label="More stories">
    <div class="section-wrap">
      <h2 class="section-title">More Stories</h2>
      <div class="card-grid">

        <a href="/articles/pagcor-b2b-system-decommissioning-august-2026.html" class="card">
          <div class="card-img">
            <img src="/hero/pagcor-b2b-system-decommissioning-august-2026.png"
                 alt="PAGCOR decommissioning non-compliant B2B gaming systems August 2026"
                 width="640" height="360" loading="lazy">
          </div>
          <div class="card-body">
            <span class="tag tag-news">News</span>
            <h3>PAGCOR Sets August 1 Deadline to Decommission Non-Compliant B2B Gaming Systems</h3>
            <p class="card-dek">A May 21 PAGCOR memorandum gives every B2B supplier in the Philippine online gaming sector until July 31 to clear fresh accreditation, or face decommissioning of their platforms and equipment from August 1.</p>
            <p class="card-meta">May 28, 2026 &middot; Score 9/10</p>
          </div>
        </a>

        <a href="/articles/cambodia-revokes-zhong-huawei-casino-license.html" class="card">
          <div class="card-img">
            <img src="/hero/cambodia-revokes-zhong-huawei-casino-license.png"
                 alt="Cambodia revokes Zhong Huawei Sihanoukville casino license"
                 width="640" height="360" loading="lazy">
          </div>
          <div class="card-body">
            <span class="tag tag-news">News</span>
            <h3>Cambodia Revokes Zhong Huawei Casino License as Sihanoukville Crackdown Hits Eight Operators</h3>
            <p class="card-dek">Cambodia's CGMC revoked the license of Casino Zhong Huawei Golden Sand on April 30, three weeks after a joint raid detained 104 foreign nationals and seized nearly 1,600 devices. Eight casinos have now lost licenses since April.</p>
            <p class="card-meta">May 28, 2026 &middot; Score 9/10</p>
          </div>
        </a>

        <a href="/articles/bingoplus-anniversary-2026-payouts.html" class="card">
          <div class="card-img">
            <img src="/hero/bingoplus-anniversary-2026-payouts.png"
                 alt="BingoPlus 2026 anniversary PHP 2.25 trillion cumulative payouts"
                 width="640" height="360" loading="lazy">
          </div>
          <div class="card-body">
            <span class="tag tag-news">News</span>
            <h3>BingoPlus Reports PHP 2.25 Trillion in Cumulative Payouts at 2026 Anniversary</h3>
            <p class="card-dek">DigiPlus Interactive's flagship online bingo platform marked its anniversary in Pasay City on May 19, 2026 with a headline figure of PHP 2.25 trillion in cumulative payouts to over three million verified Filipino users since launch.</p>
            <p class="card-meta">May 28, 2026 &middot; Score 9/10</p>
          </div>
        </a>

        <a href="/articles/gcash-casino-partnerships-q2-2026.html" class="card">
          <div class="card-img">
            <img src="/hero/gcash-casino-partnerships-q2-2026.png"
                 alt="GCash e-wallet bridging Philippine casino operators"
                 width="640" height="360" loading="lazy">
          </div>
          <div class="card-body">
            <span class="tag tag-news">News</span>
            <h3>GCash Casino Partnerships Hit 47 in Q2 2026 as Cashless Push Accelerates</h3>
            <p class="card-dek">The largest Philippine e-wallet now integrates with nearly every PIGO and e-Games operator, reshaping how players fund accounts and how regulators monitor the flow.</p>
            <p class="card-meta">May 26, 2026 &middot; Score 9/10</p>
          </div>
        </a>

      </div>
    </div>
  </section>

</BaseLayout>
