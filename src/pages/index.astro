---
import BaseLayout from '../layouts/BaseLayout.astro';

const siteUrl = 'https://phgamingintel.com';

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      "name": "PH Gaming Intel",
      "url": `${siteUrl}/`,
      "description": "Philippines gaming industry news, regulatory analysis, and data tools.",
      "publisher": { "@id": `${siteUrl}/#organization` },
      "potentialAction": {
        "@type": "SearchAction",
        "target": `${siteUrl}/?s={search_term_string}`,
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@type": "Organization",
      "@id": `${siteUrl}/#organization`,
      "name": "PH Gaming Intel",
      "url": `${siteUrl}/`,
      "logo": { "@type": "ImageObject", "url": `${siteUrl}/logo.png` },
      "sameAs": []
    },
    {
      "@type": "ItemList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "How to Bet on the 2026 FIFA World Cup Legally in the Philippines: A PAGCOR-Licensed Sportsbook Guide", "url": `${siteUrl}/articles/how-to-bet-fifa-world-cup-2026-philippines-pagcor.html` },
        { "@type": "ListItem", "position": 2, "name": "PAGCOR-Licensed Sportsbooks Brace for a World Cup Betting Surge", "url": `${siteUrl}/articles/pagcor-sportsbooks-world-cup-2026-betting-surge.html` },
        { "@type": "ListItem", "position": 3, "name": "Will the World Cup Move the Needle on Philippine Sports Betting GGR? Doing the Math on the 15% Rate", "url": `${siteUrl}/articles/world-cup-2026-philippine-sports-betting-ggr-analysis.html` },
