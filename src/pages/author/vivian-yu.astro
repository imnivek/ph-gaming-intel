---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE, articlesSortedByDate, articleUrl } from '../../data/articles';

const author = SITE.author;
const recentArticles = articlesSortedByDate().slice(0, 9);

const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": `${SITE.url}/author/${author.slug}`,
  "name": author.name,
  "jobTitle": author.title,
  "description": author.bio,
  "email": author.email,
  "url": `${SITE.url}/author/${author.slug}`,
  "worksFor": {
    "@type": "Organization",
    "name": SITE.name,
    "url": SITE.url,
  },
  "knowsAbout": [
    "PAGCOR regulation",
    "Philippine gaming industry",
    "POGO transition",
    "Southeast Asian gaming policy",
    "Online gaming licensing",
    "Integrated resort operations",
  ],
};
---

<BaseLayout
  title={`${author.name}, ${author.title} | ${SITE.name}`}
  description={author.bio}
  ogType="profile"
  jsonLd={personJsonLd}
>
  <section class="mt-section mb-section">
    <div class="section-wrap" style="max-width: 760px;">
      <div class="author-bio" style="margin-top: 32px;">
        <div class="avatar" style="font-size: 24px; width: 80px; height: 80px;">VY</div>
        <div class="bio-text">
          <h1 style="font-size: 32px; margin: 0 0 8px;">{author.name}</h1>
          <p style="color: var(--gold); font-family: var(--font-ui); text-transform: uppercase; letter-spacing: 1px; font-size: 14px; margin: 0 0 16px;">{author.title}</p>
          <p style="font-size: 17px; line-height: 1.7;">{author.bio}</p>
          <p style="font-size: 15px; color: #888; margin-top: 16px;">
            Editorial contact: <a href={`mailto:${author.email}`} style="color: var(--gold);">{author.email}</a>
          </p>
        </div>
      </div>

      <h2 class="section-title" style="margin-top: 48px;">Recent Coverage</h2>
      <div class="card-grid">
        {recentArticles.map((a) => (
          <a href={`/articles/${a.slug}.html`} class="card">
            <div class="card-img">
              <img src={a.heroImage} alt={a.title} width="640" height="360" loading="lazy" />
            </div>
            <div class="card-body">
              <span class={`tag tag-${a.category.toLowerCase()}`}>{a.category}</span>
              <h3>{a.title}</h3>
              <p class="card-dek">{a.description}</p>
              <p class="card-meta">{new Date(a.publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
