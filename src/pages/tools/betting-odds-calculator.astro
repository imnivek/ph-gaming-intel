---
import BaseLayout from '../../layouts/BaseLayout.astro';

const siteUrl = 'https://phgamingintel.com';
const pageUrl = `${siteUrl}/tools/betting-odds-calculator`;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "@id": `${pageUrl}#app`,
      "name": "Betting Odds & Implied Probability Calculator",
      "url": pageUrl,
      "applicationCategory": "FinanceApplication",
      "operatingSystem": "Any",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "PHP" },
      "description": "A free educational calculator that converts betting odds into payout, profit, implied probability, and the bookmaker's margin. Built for understanding the house edge, not for predicting winners.",
      "publisher": { "@type": "Organization", "name": "PH Gaming Intel", "url": `${siteUrl}/` }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": `${siteUrl}/` },
        { "@type": "ListItem", "position": 2, "name": "Tools", "item": `${siteUrl}/tools/betting-odds-calculator` },
        { "@type": "ListItem", "position": 3, "name": "Betting Odds Calculator", "item": pageUrl }
      ]
    }
  ]
};
---

<BaseLayout
  title="Betting Odds & Implied Probability Calculator — PH Gaming Intel"
  description="A free educational tool: enter decimal odds and a stake to see your payout, profit, and the implied probability — then add a full market to see the bookmaker's margin (the house edge). Built to help you understand what a sportsbook is really offering, not to predict winners."
  activePage=""
  jsonLd={jsonLd}
>

  <section class="tool-wrap">

    <nav class="tool-breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a> <span>&rsaquo;</span> <span>Tools</span> <span>&rsaquo;</span> <span aria-current="page">Betting Odds Calculator</span>
    </nav>

    <header class="tool-head">
      <h1>Betting Odds &amp; Implied Probability Calculator</h1>
      <p class="tool-dek">Enter the odds and your stake to see the payout, profit, and the <strong>implied probability</strong> the price is really assigning. Then add a full market to reveal the <strong>bookmaker's margin</strong> — the structural house edge baked into every bet. This is an educational tool, not a tipster: it shows you what a sportsbook is offering and why the numbers are never a fair coin.</p>
    </header>

    <!-- CALCULATOR 1: PAYOUT + IMPLIED PROBABILITY -->
    <div class="calc-card">
      <h2>1. Payout &amp; implied probability</h2>
      <p class="calc-note">Decimal odds are the format you'll mostly see on PAGCOR-licensed platforms. Stake is in PHP.</p>

      <div class="calc-inputs">
        <label>
          <span>Decimal odds</span>
          <input type="number" id="odds1" value="2.50" min="1.01" step="0.01" inputmode="decimal" />
        </label>
        <label>
          <span>Stake (PHP)</span>
          <input type="number" id="stake1" value="100" min="0" step="1" inputmode="decimal" />
        </label>
      </div>

      <div class="calc-results" id="results1">
        <div class="result-item"><div class="result-num" id="r-return">—</div><div class="result-label">Total return</div></div>
        <div class="result-item"><div class="result-num" id="r-profit">—</div><div class="result-label">Profit if it wins</div></div>
        <div class="result-item"><div class="result-num" id="r-prob">—</div><div class="result-label">Implied probability</div></div>
      </div>
      <p class="calc-formula">Implied probability = 1 &divide; decimal odds. Total return = stake &times; decimal odds.</p>
    </div>

    <!-- CALCULATOR 2: BOOKMAKER MARGIN -->
    <div class="calc-card">
      <h2>2. Bookmaker margin (the house edge)</h2>
      <p class="calc-note">Enter the decimal odds for every outcome in a market. A fair market would sum to exactly 100%. Anything over 100% is the operator's margin — the part that tilts the math toward the house no matter who wins. A football match has three outcomes (home / draw / away); a two-way market like over/under has two.</p>

      <div class="calc-inputs calc-inputs-3">
        <label>
          <span>Outcome 1 (e.g. Home)</span>
          <input type="number" id="m1" value="2.10" min="1.01" step="0.01" inputmode="decimal" />
        </label>
        <label>
          <span>Outcome 2 (e.g. Draw)</span>
          <input type="number" id="m2" value="3.40" min="1.01" step="0.01" inputmode="decimal" />
        </label>
        <label>
          <span>Outcome 3 (e.g. Away)</span>
          <input type="number" id="m3" value="3.60" min="0" step="0.01" inputmode="decimal" placeholder="leave 0 if 2-way" />
        </label>
      </div>

      <div class="calc-results">
        <div class="result-item"><div class="result-num" id="r-implied-total">—</div><div class="result-label">Implied probabilities total</div></div>
        <div class="result-item result-item-hl"><div class="result-num" id="r-margin">—</div><div class="result-label">Bookmaker margin</div></div>
      </div>
      <div id="margin-breakdown" class="margin-breakdown"></div>
      <p class="calc-formula">Margin = (sum of 1 &divide; odds for every outcome) &minus; 100%. The bigger the margin, the worse the value for the bettor.</p>
    </div>

    <!-- HONEST FRAMING -->
    <div class="tool-disclaimer">
      <h3>What this tool does — and doesn't — tell you</h3>
      <p>This calculator shows you the arithmetic behind a betting line: what you'd be paid, what probability the price implies, and how much margin the operator has built in. It does <strong>not</strong> tell you what to bet, predict any result, or improve your odds of winning. No amount of calculation removes the house edge — that edge is the point of the business. The honest use of this tool is defensive: to see exactly what you're paying for before you decide whether it's worth it.</p>
      <p class="tool-rg">18+ only. Bet only on a <a href="/articles/how-to-bet-fifa-world-cup-2026-philippines-pagcor.html">PAGCOR-licensed sportsbook</a>, set a deposit limit in advance, and treat any stake as the price of entertainment. If gambling stops feeling optional, the <a href="/articles/responsible-betting-world-cup-2026-pagcor-self-exclusion.html">National Problem Gambling Helpline and self-exclusion tools</a> are there for that.</p>
    </div>

    <div class="tool-related">
      <h3>Learn the concepts behind the numbers</h3>
      <ul>
        <li><a href="/articles/football-betting-odds-explained-world-cup-2026.html">Football Betting Odds Explained: How to Read World Cup Markets Without Fooling Yourself</a></li>
        <li><a href="/articles/live-in-play-betting-explained-world-cup-2026.html">Live (In-Play) Betting Explained: The Product the World Cup Is Built to Sell</a></li>
        <li><a href="/articles/how-to-bet-fifa-world-cup-2026-philippines-pagcor.html">How to Bet on the 2026 FIFA World Cup Legally in the Philippines</a></li>
        <li><a href="/sports-betting">All Sports Betting coverage &rsaquo;</a></li>
      </ul>
    </div>

  </section>

  <style>
    .tool-wrap { max-width: 820px; margin: 0 auto; padding: 40px 24px 80px; }
    .tool-breadcrumb { font-family: var(--font-ui); font-size: 12px; color: var(--text-light); margin-bottom: 20px; }
    .tool-breadcrumb a { color: var(--text-light); text-decoration: none; }
    .tool-breadcrumb a:hover { color: var(--gold); }
    .tool-breadcrumb span { margin: 0 4px; }
    .tool-head h1 { font-family: var(--font-body); font-size: 36px; line-height: 1.2; color: var(--dark); margin: 0 0 16px; font-weight: 800; }
    .tool-dek { font-family: var(--font-body); font-size: 18px; line-height: 1.6; color: var(--text); margin-bottom: 36px; }

    .calc-card { background: #fff; border: 1px solid var(--border); border-radius: 14px; padding: 28px; margin-bottom: 28px; box-shadow: 0 2px 12px rgba(13,27,42,.05); }
    .calc-card h2 { font-family: var(--font-ui); font-size: 20px; font-weight: 700; color: var(--navy); margin: 0 0 8px; }
    .calc-note { font-family: var(--font-ui); font-size: 14px; line-height: 1.6; color: var(--text-light); margin: 0 0 22px; }

    .calc-inputs { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; margin-bottom: 24px; }
    .calc-inputs-3 { grid-template-columns: 1fr 1fr 1fr; }
    .calc-inputs label { display: flex; flex-direction: column; gap: 7px; }
    .calc-inputs label span { font-family: var(--font-ui); font-size: 13px; font-weight: 600; color: var(--text); }
    .calc-inputs input { font-family: var(--font-ui); font-size: 20px; font-weight: 600; color: var(--dark); padding: 12px 14px; border: 2px solid var(--border); border-radius: 9px; background: var(--cream); width: 100%; box-sizing: border-box; }
    .calc-inputs input:focus { outline: none; border-color: var(--gold); background: #fff; }

    .calc-results { display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 14px; margin-bottom: 14px; }
    .result-item { background: var(--dark); border-radius: 11px; padding: 18px 16px; text-align: center; }
    .result-item-hl { background: var(--brick); }
    .result-num { font-family: var(--font-ui); font-size: 26px; font-weight: 800; color: var(--gold); line-height: 1.1; }
    .result-item-hl .result-num { color: #fff; }
    .result-label { font-family: var(--font-ui); font-size: 11px; font-weight: 600; letter-spacing: .5px; text-transform: uppercase; color: rgba(255,255,255,.65); margin-top: 7px; }

    .calc-formula { font-family: var(--font-ui); font-size: 12.5px; color: var(--text-light); font-style: italic; margin: 6px 0 0; }
    .margin-breakdown { font-family: var(--font-ui); font-size: 13px; color: var(--text); margin: 4px 0 12px; line-height: 1.7; }
    .margin-breakdown span { display: inline-block; background: var(--cream); border: 1px solid var(--border); border-radius: 6px; padding: 3px 9px; margin: 0 6px 6px 0; }

    .tool-disclaimer { background: var(--cream); border-left: 4px solid var(--gold); border-radius: 8px; padding: 24px 26px; margin-bottom: 28px; }
    .tool-disclaimer h3 { font-family: var(--font-ui); font-size: 16px; font-weight: 700; color: var(--navy); margin: 0 0 12px; }
    .tool-disclaimer p { font-family: var(--font-body); font-size: 16px; line-height: 1.6; color: var(--text); margin: 0 0 12px; }
    .tool-disclaimer p:last-child { margin-bottom: 0; }
    .tool-rg { font-size: 14px !important; color: var(--text-light) !important; }
    .tool-disclaimer a { color: var(--brick); font-weight: 600; }

    .tool-related h3 { font-family: var(--font-ui); font-size: 16px; font-weight: 700; color: var(--navy); margin: 0 0 14px; }
    .tool-related ul { list-style: none; padding: 0; margin: 0; }
    .tool-related li { border-bottom: 1px solid var(--border); padding: 11px 0; }
    .tool-related a { font-family: var(--font-body); font-size: 16px; color: var(--text); text-decoration: none; }
    .tool-related a:hover { color: var(--gold); }

    @media (max-width: 560px) {
      .tool-head h1 { font-size: 28px; }
      .calc-inputs, .calc-inputs-3 { grid-template-columns: 1fr; }
    }
  </style>

  <script is:inline>
    (function () {
      var peso = function (n) {
        return 'PHP ' + n.toLocaleString('en-PH', { maximumFractionDigits: 2 });
      };

      // --- Calculator 1: payout + implied probability ---
      var odds1 = document.getElementById('odds1');
      var stake1 = document.getElementById('stake1');
      var rReturn = document.getElementById('r-return');
      var rProfit = document.getElementById('r-profit');
      var rProb = document.getElementById('r-prob');

      function calc1() {
        var o = parseFloat(odds1.value);
        var s = parseFloat(stake1.value);
        if (!isFinite(o) || o < 1.01 || !isFinite(s) || s < 0) {
          rReturn.textContent = '—'; rProfit.textContent = '—'; rProb.textContent = '—';
          return;
        }
        var total = s * o;
        rReturn.textContent = peso(total);
        rProfit.textContent = peso(total - s);
        rProb.textContent = (100 / o).toFixed(1) + '%';
      }

      odds1.addEventListener('input', calc1);
      stake1.addEventListener('input', calc1);

      // --- Calculator 2: bookmaker margin ---
      var m1 = document.getElementById('m1');
      var m2 = document.getElementById('m2');
      var m3 = document.getElementById('m3');
      var rImpliedTotal = document.getElementById('r-implied-total');
      var rMargin = document.getElementById('r-margin');
      var breakdown = document.getElementById('margin-breakdown');

      function calc2() {
        var vals = [m1.value, m2.value, m3.value].map(parseFloat);
        var sum = 0, parts = [], valid = 0;
        for (var i = 0; i < vals.length; i++) {
          var v = vals[i];
          if (isFinite(v) && v >= 1.01) {
            var p = 100 / v;
            sum += p;
            valid++;
            parts.push('Outcome ' + (i + 1) + ': ' + p.toFixed(1) + '%');
          }
        }
        if (valid < 2) {
          rImpliedTotal.textContent = '—'; rMargin.textContent = '—'; breakdown.innerHTML = '';
          return;
        }
        rImpliedTotal.textContent = sum.toFixed(1) + '%';
        var margin = sum - 100;
        rMargin.textContent = (margin >= 0 ? '' : '') + margin.toFixed(1) + '%';
        breakdown.innerHTML = parts.map(function (p) { return '<span>' + p + '</span>'; }).join('');
      }

      [m1, m2, m3].forEach(function (el) { el.addEventListener('input', calc2); });

      calc1();
      calc2();
    })();
  </script>

</BaseLayout>
