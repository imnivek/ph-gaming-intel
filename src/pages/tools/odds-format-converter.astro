---
import BaseLayout from '../../layouts/BaseLayout.astro';

const siteUrl = 'https://phgamingintel.com';
const pageUrl = `${siteUrl}/tools/odds-format-converter`;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "@id": `${pageUrl}#app`,
      "name": "Betting Odds Format Converter",
      "url": pageUrl,
      "applicationCategory": "FinanceApplication",
      "operatingSystem": "Any",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "PHP" },
      "description": "A free educational converter between decimal, American (moneyline), and fractional odds, and the implied probability each price assigns. Enter any one format to see the others instantly.",
      "publisher": { "@type": "Organization", "name": "PH Gaming Intel", "url": `${siteUrl}/` }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": `${siteUrl}/` },
        { "@type": "ListItem", "position": 2, "name": "Tools", "item": pageUrl },
        { "@type": "ListItem", "position": 3, "name": "Odds Format Converter", "item": pageUrl }
      ]
    }
  ]
};
---

<BaseLayout
  title="Betting Odds Format Converter (Decimal, American, Fractional) — PH Gaming Intel"
  description="A free educational tool that converts between decimal, American (moneyline), and fractional odds — and shows the implied probability each price assigns. Enter any one format to see the rest instantly. Built to help you read a betting line, not to predict winners."
  activePage=""
  jsonLd={jsonLd}
>

  <section class="tool-wrap">

    <nav class="tool-breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a> <span>&rsaquo;</span> <span>Tools</span> <span>&rsaquo;</span> <span aria-current="page">Odds Format Converter</span>
    </nav>

    <header class="tool-head">
      <h1>Betting Odds Format Converter</h1>
      <p class="tool-dek">The same price can be written three ways — <strong>decimal</strong> (2.50), <strong>American</strong> / moneyline (+150), or <strong>fractional</strong> (3/2) — and every price also assigns an <strong>implied probability</strong>. Enter any one format below and the rest update instantly. This is an educational tool for reading a line clearly; it does not predict results or improve your odds.</p>
    </header>

    <!-- CONVERTER -->
    <div class="calc-card">
      <h2>Convert an odds price</h2>
      <p class="calc-note">Choose the format you have, type the value, and read the others. American odds take a sign (e.g. +150 or -200); fractional odds use a slash (e.g. 5/2).</p>

      <div class="calc-inputs">
        <label>
          <span>Input format</span>
          <select id="inFormat">
            <option value="decimal">Decimal (e.g. 2.50)</option>
            <option value="american">American / moneyline (e.g. +150)</option>
            <option value="fractional">Fractional (e.g. 3/2)</option>
            <option value="probability">Implied probability % (e.g. 40)</option>
          </select>
        </label>
        <label>
          <span>Value</span>
          <input type="text" id="inValue" value="2.50" inputmode="text" autocomplete="off" />
        </label>
      </div>

      <div class="calc-results calc-results-4">
        <div class="result-item"><div class="result-num" id="outDecimal">—</div><div class="result-label">Decimal</div></div>
        <div class="result-item"><div class="result-num" id="outAmerican">—</div><div class="result-label">American</div></div>
        <div class="result-item"><div class="result-num" id="outFractional">—</div><div class="result-label">Fractional</div></div>
        <div class="result-item result-item-hl"><div class="result-num" id="outProb">—</div><div class="result-label">Implied probability</div></div>
      </div>
      <p class="calc-formula" id="convHint">Implied probability = 1 &divide; decimal odds. Decimal 2.00 = American +100 = fractional 1/1 = 50%.</p>
    </div>

    <!-- HONEST FRAMING -->
    <div class="tool-disclaimer">
      <h3>Reading a price is not beating it</h3>
      <p>Converting formats makes a line easier to read, but it changes nothing about the value. The implied probability a price assigns already includes the bookmaker's margin, so the percentages across a full market always add up to more than 100% — that excess is the house edge, and no format hides it or removes it. Use this tool to understand exactly what a sportsbook is offering; use the <a href="/tools/betting-odds-calculator">odds &amp; margin calculator</a> to see the edge inside a whole market.</p>
      <p class="tool-rg">18+ only. Bet only on a <a href="/articles/how-to-bet-fifa-world-cup-2026-philippines-pagcor.html">PAGCOR-licensed sportsbook</a>, set a deposit limit in advance, and treat any stake as the price of entertainment. If gambling stops feeling optional, the <a href="/tools/responsible-gambling-self-assessment">responsible-gambling self-assessment</a> and the National Problem Gambling Helpline (02) 8248-9568 are there for that.</p>
    </div>

    <div class="tool-related">
      <h3>Learn the concepts behind the numbers</h3>
      <ul>
        <li><a href="/articles/football-betting-odds-explained-world-cup-2026.html">Football Betting Odds Explained: How to Read World Cup Markets Without Fooling Yourself</a></li>
        <li><a href="/tools/betting-odds-calculator">Betting Odds &amp; Implied Probability Calculator</a></li>
        <li><a href="/tools/parlay-margin-calculator">Parlay &amp; Accumulator Margin Calculator</a></li>
        <li><a href="/sports-betting">All Sports Betting coverage &rsaquo;</a></li>
      </ul>
    </div>

  </section>

  <style>
    .tool-wrap { max-width: 820px; margin: 0 auto; padding: 40px 24px 80px; }
    .tool-breadcrumb { font-family: var(--font-ui); font-size: 12px; color: var(--text-light); margin-bottom: 20px; }
    .tool-breadcrumb a { color: var(--text-light); text-decoration: none; }
    .tool-breadcrumb a:hover { color: var(--gold); }
    .tool-breadcrumb span { margin: 0 4px; }
    .tool-head h1 { font-family: var(--font-body); font-size: 36px; line-height: 1.2; color: var(--dark); margin: 0 0 16px; font-weight: 800; }
    .tool-dek { font-family: var(--font-body); font-size: 18px; line-height: 1.6; color: var(--text); margin-bottom: 36px; }

    .calc-card { background: #fff; border: 1px solid var(--border); border-radius: 14px; padding: 28px; margin-bottom: 28px; box-shadow: 0 2px 12px rgba(13,27,42,.05); }
    .calc-card h2 { font-family: var(--font-ui); font-size: 20px; font-weight: 700; color: var(--navy); margin: 0 0 8px; }
    .calc-note { font-family: var(--font-ui); font-size: 14px; line-height: 1.6; color: var(--text-light); margin: 0 0 22px; }

    .calc-inputs { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; margin-bottom: 24px; }
    .calc-inputs label { display: flex; flex-direction: column; gap: 7px; }
    .calc-inputs label span { font-family: var(--font-ui); font-size: 13px; font-weight: 600; color: var(--text); }
    .calc-inputs input, .calc-inputs select { font-family: var(--font-ui); font-size: 20px; font-weight: 600; color: var(--dark); padding: 12px 14px; border: 2px solid var(--border); border-radius: 9px; background: var(--cream); width: 100%; box-sizing: border-box; }
    .calc-inputs input:focus, .calc-inputs select:focus { outline: none; border-color: var(--gold); background: #fff; }

    .calc-results { display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 14px; margin-bottom: 14px; }
    .calc-results-4 { grid-template-columns: repeat(4, 1fr); }
    .result-item { background: var(--dark); border-radius: 11px; padding: 18px 16px; text-align: center; }
    .result-item-hl { background: var(--brick); }
    .result-num { font-family: var(--font-ui); font-size: 24px; font-weight: 800; color: var(--gold); line-height: 1.1; }
    .result-item-hl .result-num { color: #fff; }
    .result-label { font-family: var(--font-ui); font-size: 11px; font-weight: 600; letter-spacing: .5px; text-transform: uppercase; color: rgba(255,255,255,.65); margin-top: 7px; }

    .calc-formula { font-family: var(--font-ui); font-size: 12.5px; color: var(--text-light); font-style: italic; margin: 6px 0 0; }

    .tool-disclaimer { background: var(--cream); border-left: 4px solid var(--gold); border-radius: 8px; padding: 24px 26px; margin-bottom: 28px; }
    .tool-disclaimer h3 { font-family: var(--font-ui); font-size: 16px; font-weight: 700; color: var(--navy); margin: 0 0 12px; }
    .tool-disclaimer p { font-family: var(--font-body); font-size: 16px; line-height: 1.6; color: var(--text); margin: 0 0 12px; }
    .tool-disclaimer p:last-child { margin-bottom: 0; }
    .tool-rg { font-size: 14px !important; color: var(--text-light) !important; }
    .tool-disclaimer a { color: var(--brick); font-weight: 600; }

    .tool-related h3 { font-family: var(--font-ui); font-size: 16px; font-weight: 700; color: var(--navy); margin: 0 0 14px; }
    .tool-related ul { list-style: none; padding: 0; margin: 0; }
    .tool-related li { border-bottom: 1px solid var(--border); padding: 11px 0; }
    .tool-related a { font-family: var(--font-body); font-size: 16px; color: var(--text); text-decoration: none; }
    .tool-related a:hover { color: var(--gold); }

    @media (max-width: 560px) {
      .tool-head h1 { font-size: 28px; }
      .calc-inputs { grid-template-columns: 1fr; }
      .calc-results-4 { grid-template-columns: 1fr 1fr; }
    }
  </style>

  <script is:inline>
    (function () {
      var inFormat = document.getElementById('inFormat');
      var inValue = document.getElementById('inValue');
      var outDecimal = document.getElementById('outDecimal');
      var outAmerican = document.getElementById('outAmerican');
      var outFractional = document.getElementById('outFractional');
      var outProb = document.getElementById('outProb');

      function clear() {
        outDecimal.textContent = '—'; outAmerican.textContent = '—';
        outFractional.textContent = '—'; outProb.textContent = '—';
      }

      // decimal (>1) to a simple fraction of (decimal - 1) via continued fractions
      function toFraction(value) {
        if (value <= 0) return '0/1';
        var tol = 1e-6, h1 = 1, h2 = 0, k1 = 0, k2 = 1, b = value, iter = 0;
        do {
          var a = Math.floor(b);
          var aux = h1; h1 = a * h1 + h2; h2 = aux;
          aux = k1; k1 = a * k1 + k2; k2 = aux;
          var denom = b - a;
          if (Math.abs(denom) < 1e-9) break;
          b = 1 / denom;
          iter++;
        } while (Math.abs(value - h1 / k1) > tol && k1 < 1000 && iter < 30);
        return h1 + '/' + k1;
      }

      function amFromDecimal(d) {
        if (d >= 2) return '+' + Math.round((d - 1) * 100);
        return '-' + Math.round(100 / (d - 1));
      }

      // parse the input into a decimal odds value, or null
      function toDecimal() {
        var fmt = inFormat.value;
        var raw = (inValue.value || '').trim();
        if (!raw) return null;
        if (fmt === 'decimal') {
          var d = parseFloat(raw);
          return (isFinite(d) && d > 1) ? d : null;
        }
        if (fmt === 'american') {
          var a = parseFloat(raw.replace('+', ''));
          if (!isFinite(a) || a === 0) return null;
          return a > 0 ? (a / 100 + 1) : (100 / Math.abs(a) + 1);
        }
        if (fmt === 'fractional') {
          var parts = raw.split('/');
          if (parts.length !== 2) return null;
          var n = parseFloat(parts[0]), den = parseFloat(parts[1]);
          if (!isFinite(n) || !isFinite(den) || den <= 0 || n < 0) return null;
          return n / den + 1;
        }
        if (fmt === 'probability') {
          var p = parseFloat(raw);
          if (!isFinite(p) || p <= 0 || p >= 100) return null;
          return 100 / p;
        }
        return null;
      }

      function convert() {
        var d = toDecimal();
        if (d === null) { clear(); return; }
        outDecimal.textContent = d.toFixed(2);
        outAmerican.textContent = amFromDecimal(d);
        outFractional.textContent = toFraction(d - 1);
        outProb.textContent = (100 / d).toFixed(1) + '%';
      }

      // set a sensible placeholder value when the format changes
      inFormat.addEventListener('change', function () {
        var defaults = { decimal: '2.50', american: '+150', fractional: '3/2', probability: '40' };
        inValue.value = defaults[inFormat.value] || '';
        convert();
      });
      inValue.addEventListener('input', convert);

      convert();
    })();
  </script>

</BaseLayout>
